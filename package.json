{
  "name": "@fsichi/awswiz",
  "version": "0.2.0",
  "description": "Friendly AWS credentials CLI — interactive wizards for profiles, MFA, assume-role, SSO and more",
  "keywords": [
    "aws",
    "cli",
    "credentials",
    "mfa",
    "sso",
    "assume-role",
    "profiles",
    "wizard"
  ],
  "license": "MIT",
  "author": "Facundo Sichi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FSichi/awswiz.git"
  },
  "bugs": {
    "url": "https://github.com/FSichi/awswiz/issues"
  },
  "homepage": "https://github.com/FSichi/awswiz#readme",
  "type": "module",
  "bin": {
    "awswiz": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "^3.700.0",
    "@aws-sdk/client-sso-oidc": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@clack/prompts": "^1.5.1",
    "@smithy/shared-ini-file-loader": "^4.6.1",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
